{
    "root": true,
    "env": {
        "browser": true,
        "node": true,
        "es2022": true
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-undef": "error",
        "semi": ["warn", "always"],
        "prefer-const": "warn",
        "eqeqeq": ["warn", "smart"],
        "no-console": "off"
    }
}
