{
    "name": "canvas-vampire-survivors",
    "version": "2.4.0",
    "description": "Vanilla JavaScript HTML5 Canvas roguelite inspired by Vampire Survivors. Zero runtime dependencies.",
    "main": "server.js",
    "type": "commonjs",
    "private": false,
    "scripts": {
        "start": "node server.js",
        "dev": "node server.js",
        "lint": "eslint \"src/**/*.js\" \"test/**/*.js\" server.js",
        "lint:fix": "eslint --fix \"src/**/*.js\" \"test/**/*.js\" server.js",
        "format": "prettier --write \"**/*.{js,html,css,md,json}\"",
        "format:check": "prettier --check \"**/*.{js,html,css,md,json}\"",
        "test": "node --test test/*.test.js",
        "check": "npm run lint && npm run format:check && npm test"
    },
    "keywords": [
        "game",
        "html5",
        "html5-canvas-game",
        "canvas",
        "roguelite",
        "vampire-survivors",
        "vampire-survivors-clone",
        "browser-roguelite",
        "bullet-hell",
        "browser-game",
        "vanilla-js",
        "zero-dependencies",
        "indie-game",
        "speedrun",
        "open-source"
    ],
    "author": "Survivor contributors",
    "license": "MIT",
    "engines": {
        "node": ">=18"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ricardo-M-L/canvas-vampire-survivors.git"
    },
    "bugs": {
        "url": "https://github.com/Ricardo-M-L/canvas-vampire-survivors/issues"
    },
    "homepage": "https://github.com/Ricardo-M-L/canvas-vampire-survivors#readme",
    "devDependencies": {
        "eslint": "^9.0.0",
        "prettier": "^3.2.0"
    }
}
